# ============================================================
#  RealtyAI — Environment Variables
#  Copie este arquivo para .env e preencha os valores
#  cp .env.example .env
# ============================================================

# --- App ---
APP_NAME=RealtyAI
APP_VERSION=1.0.0
DEBUG=True

# --- Database ---
# SQLite (padrão para desenvolvimento)
DATABASE_URL=sqlite+aiosqlite:///./database/database.db
# PostgreSQL (produção) — descomente e configure:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/realtyai

# --- JWT Security ---
# IMPORTANTE: Mude estas chaves em produção!
JWT_SECRET_KEY=mude-esta-chave-secreta-em-producao-abc123xyz
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Admin (Single User) ---
ADMIN_EMAIL=admin@realtyai.com
ADMIN_PASSWORD=realtyai2024
ADMIN_NAME=Administrador

# --- OpenRouter ---
# Obtenha sua chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=RealtyAI

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
